# Copy to .env on the Fedora ProBook. NEVER commit.

# Brain websocket — your ProLiant's Tailscale IP
JARVIS_BRAIN_URL=ws://100.119.210.126:8765

# Must match the JARVIS_FRONTEND_SECRET on the brain
JARVIS_FRONTEND_SECRET=REPLACE_ME_WITH_RANDOM_HEX

# Set to 1 to disable wake word and use Enter-to-talk instead
JARVIS_PUSH_TO_TALK=0

# openWakeWord model name
WAKE_WORD_MODEL=hey_jarvis_v0.1
