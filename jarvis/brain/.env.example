# Copy to .env (which IS gitignored) and fill in real values.
# Never commit .env itself.

# Get your key from https://console.anthropic.com — set a $15 monthly cap first
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Random string, 32+ chars. Generate with: openssl rand -hex 32
JARVIS_FRONTEND_SECRET=REPLACE_ME_WITH_RANDOM_HEX

# Optional — if you enable Home Assistant
HOMEASSISTANT_TOKEN=
